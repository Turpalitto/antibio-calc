{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AntibioDB — КР МЗ РФ",
  "description": "Схема базы данных антибактериальной терапии по клиническим рекомендациям Минздрава РФ. Только верифицированные данные. Отсутствие данных = null.",
  "type": "object",
  "required": ["meta", "recommendations"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["version", "generated_at", "sources_base", "verification_status"],
      "properties": {
        "version": {"type": "string"},
        "generated_at": {"type": "string"},
        "sources_base": {"type": "string"},
        "verification_status": {"type": "string", "enum": ["draft", "verified", "deprecated"]},
        "warning": {"type": "string"}
      }
    },
    "drugs_reference": {
      "type": "object",
      "description": "Справочник препаратов: коррекция по почкам/печени, формы, dilution, monitoring",
      "additionalProperties": {"$ref": "#/definitions/drug_reference"}
    },
    "recommendations": {
      "type": "array",
      "items": {"$ref": "#/definitions/recommendation"}
    }
  },
  "definitions": {
    "recommendation": {
      "type": "object",
      "required": ["id", "mkb10", "name", "cr_id", "cr_year", "antibiotics_indicated"],
      "properties": {
        "id": {"type": "string"},
        "mkb10": {"type": "array", "items": {"type": "string"}},
        "name": {"type": "string"},
        "synonyms": {"type": "array", "items": {"type": "string"}},
        "cr_id": {"type": "string"},
        "cr_year": {"type": "integer"},
        "cr_updated": {"type": "string"},
        "source_url": {"type": "string"},
        "antibiotics_indicated": {"type": "boolean"},
        "indications": {"type": "array", "items": {"type": "string"}},
        "age_groups": {"type": "array", "items": {"enum": ["neonate", "child", "adult", "all"]}},
        "scenarios": {"type": "array", "items": {"$ref": "#/definitions/scenario"}}
      }
    },
    "scenario": {
      "type": "object",
      "required": ["id", "name", "lines"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "age_group": {"enum": ["neonate", "child", "adult", "all"]},
        "lines": {"type": "array", "items": {"$ref": "#/definitions/line"}}
      }
    },
    "line": {
      "type": "object",
      "required": ["line_number", "drugs"],
      "properties": {
        "line_number": {"type": "integer", "description": "1 = первая линия, 2 = вторая, 0 = альтернатива при аллергии"},
        "line_label": {"type": "string"},
        "combo_therapy": {"type": "boolean", "description": "true = препараты применяются одновременно (комбинированная терапия)"},
        "drugs": {"type": "array", "items": {"$ref": "#/definitions/drug_in_scenario"}}
      }
    },
    "drug_in_scenario": {
      "type": "object",
      "required": ["route", "regimens"],
      "properties": {
        "drug_ref": {"type": "string", "description": "Ссылка на drugs_reference"},
        "combo_ref": {"type": "array", "items": {"type": "string"}, "description": "Массив ссылок для комбинированной терапии (например ['clindamycin','gentamicin'])"},
        "component_role": {"type": "string", "description": "Роль компонента в комбинации: 'main', 'anaerobe_coverage', 'atypical_coverage', 'pseudomonas_coverage'"},
        "route": {"type": "array", "items": {"enum": ["per_os", "iv", "im", "topical", "rectal", "inhalation"]}},
        "indication_note": {"type": "string"},
        "regimens": {"type": "array", "items": {"$ref": "#/definitions/regimen"}}
      }
    },
    "regimen": {
      "type": "object",
      "required": ["freq_per_day", "duration"],
      "properties": {
        "age_group": {"enum": ["neonate", "child", "adult", "all"]},
        "weight_min_kg": {"type": ["number", "null"]},
        "weight_max_kg": {"type": ["number", "null"]},
        "dose_mg_kg_day": {"type": ["number", "null"], "description": "Суточная доза мг/кг"},
        "dose_range_mg_kg_day": {"type": "array", "items": {"type": "number"}, "description": "Диапазон [min, max] мг/кг/сут по КР"},
        "dose_mg_day_fixed": {"type": ["number", "null"], "description": "Фиксированная суточная доза для взрослых"},
        "single_dose_mg": {"type": ["number", "null"]},
        "max_daily_mg": {"type": ["number", "null"]},
        "freq_per_day": {"type": "integer"},
        "duration_days": {"type": ["string", "null"]},
        "duration_note": {"type": ["string", "null"]},
        "regimen_label": {"type": "string", "description": "Подпись режима для выбора юзером (например '90 мг/кг 2 р/д')"}
      }
    },
    "drug_reference": {
      "type": "object",
      "required": ["inn", "forms"],
      "properties": {
        "inn": {"type": "string"},
        "class": {"type": "string"},
        "renal_adjustment": {"type": ["string", "null"]},
        "hepatic_adjustment": {"type": ["string", "null"]},
        "pregnancy_category": {"type": ["string", "null"]},
        "age_restriction_min": {"type": ["string", "null"]},
        "age_restriction_max": {"type": ["string", "null"]},
        "monitoring": {"type": ["string", "null"], "description": "ТЛМ, контроль уровня"},
        "interactions": {"type": ["string", "null"]},
        "storage_reconstituted": {"type": ["string", "null"], "description": "Стабильность после растворения"},
        "forms": {"type": "array", "items": {"$ref": "#/definitions/form"}},
        "dilution": {"$ref": "#/definitions/dilution"}
      }
    },
    "form": {
      "type": "object",
      "required": ["form_type", "concentration"],
      "properties": {
        "form_type": {"enum": ["tablet", "capsule", "suspension", "syrup", "solution_iv", "solution_im", "powder_for_suspension", "topical", "suppository", "granules"]},
        "concentration": {"type": "string"},
        "concentration_mg_per_ml": {"type": ["number", "null"]},
        "notes": {"type": ["string", "null"]},
        "reconstitution": {"$ref": "#/definitions/reconstitution"}
      }
    },
    "reconstitution": {
      "type": "object",
      "description": "Приготовление суспензии из порошка",
      "properties": {
        "solvent": {"type": "string", "description": "Вода очищенная / кипячёная"},
        "solvent_ml": {"type": "number"},
        "final_volume_ml": {"type": "number"},
        "steps": {"type": "array", "items": {"type": "string"}},
        "storage": {"type": "string", "description": "Срок хранения готовой суспензии"}
      }
    },
    "dilution": {
      "type": "object",
      "description": "Правила разведения для инъекционных форм",
      "properties": {
        "im": {"$ref": "#/definitions/dilution_route"},
        "iv_bolus": {"$ref": "#/definitions/dilution_route"},
        "iv_infusion": {"$ref": "#/definitions/dilution_route"}
      }
    },
    "dilution_route": {
      "type": "object",
      "properties": {
        "solvent_options": {"type": "array", "items": {"type": "object"}},
        "concentration_standard_mg_ml": {"type": "number"},
        "concentration_max_mg_ml": {"type": "number"},
        "concentration_range_mg_ml": {"type": "string"},
        "administration_time_min": {"type": "number"},
        "infusion_time_min": {"type": "number"},
        "max_per_injection_site_ml": {"type": "number"},
        "max_per_injection_site_ml_child": {"type": "number"},
        "child_solvent_warning": {"type": "string"},
        "contraindications": {"type": "string"},
        "injection_site": {"type": "string"},
        "cautions": {"type": "string"},
        "steps": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
