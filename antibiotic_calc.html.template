<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AntibioAudit — КР МЗ РФ | Калькулятор доз</title>
<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = { darkMode: 'class' };
</script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<style>
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');
:root{--primary:#2563eb;--success:#10b981;--warning:#f59e0b;--danger:#ef4444;--slate-50:#f8fafc;--slate-100:#f1f5f9;--slate-800:#1e293b}
html{scroll-behavior:smooth}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--slate-50);color:var(--slate-800);line-height:1.5}
.dark body{background:#0f172a;color:#e2e8f0}
.premium-card{background:#fff;border-radius:24px;border:1px solid rgba(226,232,240,.8);box-shadow:0 4px 6px -1px rgba(0,0,0,.02),0 10px 15px -3px rgba(0,0,0,.03);transition:all .3s}
.dark .premium-card{background:#1e293b;border-color:rgba(51,65,85,.8)}
.input-field{background:var(--slate-100);border:2px solid transparent;transition:all .2s;color:var(--slate-800)}
.dark .input-field{background:#0f172a;color:#e2e8f0;border-color:transparent}
.input-field:focus{background:#fff;border-color:var(--primary);outline:none;box-shadow:0 0 0 4px rgba(37,99,235,.1)}
.dark .input-field:focus{background:#0f172a}
.chip{cursor:pointer;border:2px solid var(--slate-100);transition:all .15s;font-weight:700;background:#fff}
.dark .chip{background:#1e293b;border-color:#334155;color:#e2e8f0}
.chip.active{background:var(--primary);color:#fff;border-color:var(--primary)}
.chip.line-1{border-color:#a7f3d0}
.chip.line-1.active{background:var(--success);border-color:var(--success)}
.chip.line-2{border-color:#bfdbfe}
.chip.line-2.active{background:var(--primary);border-color:var(--primary)}
.chip.line-0{border-color:#fde68a}
.chip.line-0.active{background:var(--warning);border-color:var(--warning);color:#78350f}
.drug-card{cursor:pointer;border:2px solid var(--slate-100);transition:all .2s;background:#fff}
.dark .drug-card{background:#1e293b;border-color:#334155}
.drug-card.active{border-color:var(--primary);background:#eff6ff}
.dark .drug-card.active{background:#1e3a8a;border-color:#3b82f6}
.scenario-card.active{border-color:var(--primary);background:#eff6ff}
.dark .scenario-card.active{background:#1e3a8a;border-color:#3b82f6}
.res-box{background:linear-gradient(135deg,#1e3a8a 0%,#2563eb 100%);box-shadow:0 20px 25px -5px rgba(37,99,235,.2)}
.inj-box{background:linear-gradient(135deg,#7c2d12 0%,#c2410c 100%);box-shadow:0 20px 25px -5px rgba(194,65,12,.25)}
.badge{font-size:10px;font-weight:800;padding:2px 8px;border-radius:6px;text-transform:uppercase}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.animate-in{animation:fadeIn .4s ease-out forwards}
.step{counter-increment:step}
.step::before{content:counter(step);display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;background:var(--primary);color:#fff;border-radius:50%;font-size:11px;font-weight:800;margin-right:8px;flex-shrink:0}
.steps{counter-reset:step;list-style:none;padding-left:0}
.steps li{padding:6px 0;display:flex;align-items:flex-start;font-size:13px;line-height:1.5}
.dilution-solvent{background:#fff7ed;border:1px solid #fed7aa;border-radius:12px;padding:10px 12px;font-size:12px;font-weight:600;color:#9a3412}
.dark .dilution-solvent{background:#451a03;border-color:#7c2d12;color:#fed7aa}
.scrollbar::-webkit-scrollbar{width:6px;height:6px}
.scrollbar::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:3px}
.route-tab.active{background:var(--primary);color:#fff;border-color:var(--primary)}
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(100px);background:#1e293b;color:#fff;padding:12px 20px;border-radius:12px;font-weight:600;font-size:13px;box-shadow:0 10px 25px rgba(0,0,0,.3);z-index:9999;opacity:0;transition:all .3s;pointer-events:none}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
@media (max-width:768px){
  .mobile-nav{display:flex}
  body{padding-bottom:70px}
}
@media print{
  .no-print{display:none!important}
  .print-only{display:block!important}
  body{background:#fff;color:#000;padding:20px;font-size:11pt}
  .premium-card{box-shadow:none;border:1px solid #ccc;background:#fff}
  .res-box,.inj-box{background:#fff;color:#000;border:2px solid #2563eb}
  .dilution-solvent{background:#fff;border:1px solid #999}
}
.print-only{display:none}
.drawer{position:fixed;top:0;right:-360px;width:360px;max-width:90vw;height:100vh;background:#fff;box-shadow:-10px 0 30px rgba(0,0,0,.15);z-index:1000;transition:right .3s;overflow-y:auto}
.dark .drawer{background:#1e293b}
.drawer.open{right:0}
.drawer-overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:999;opacity:0;pointer-events:none;transition:opacity .3s}
.drawer-overlay.open{opacity:1;pointer-events:auto}
</style>
</head>
<body class="antialiased pb-12">
<div class="max-w-3xl mx-auto px-4 md:px-6 pt-6">

  <header class="mb-6 no-print">
    <div class="flex items-center gap-3 flex-wrap">
      <div class="inline-flex items-center justify-center w-12 h-12 bg-white rounded-2xl shadow-sm border border-slate-100 dark:bg-slate-800 dark:border-slate-700">
        <i class="fas fa-user-md text-blue-600 text-xl"></i>
      </div>
      <div class="flex-1 min-w-0">
        <h1 class="text-xl md:text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">Antibio<span class="text-blue-600">Audit</span></h1>
        <p class="text-slate-400 text-[10px] font-bold mt-0.5 uppercase tracking-widest italic" id="header-stats">КР МЗ РФ • калькулятор</p>
      </div>
      <button id="btn-history" class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-blue-600 border border-slate-200 dark:border-slate-700 rounded-lg px-2 py-2" title="История расчётов">
        <i class="fas fa-history"></i>
      </button>
      <button id="btn-print" class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-blue-600 border border-slate-200 dark:border-slate-700 rounded-lg px-2 py-2" title="Печать/PDF">
        <i class="fas fa-print"></i>
      </button>
      <button id="btn-theme" class="text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-blue-600 border border-slate-200 dark:border-slate-700 rounded-lg px-2 py-2" title="Тема">
        <i class="fas fa-moon" id="theme-icon"></i>
      </button>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mt-4">
      <input type="text" id="patient-name" placeholder="Ф.И.О. пациента" class="input-field rounded-xl px-3 py-2 text-xs font-bold">
      <input type="text" id="patient-date" placeholder="Дата" class="input-field rounded-xl px-3 py-2 text-xs font-bold" onfocus="this.type='date'" onblur="if(!this.value)this.type='text'">
      <input type="number" id="patient-age" placeholder="Возраст" class="input-field rounded-xl px-3 py-2 text-xs font-bold">
      <input type="text" id="doctor-name" placeholder="Врач" class="input-field rounded-xl px-3 py-2 text-xs font-bold">
    </div>
  </header>

  <div class="space-y-5">

    <section class="premium-card p-4 md:p-6 no-print">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <div>
          <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-2 block">1. Вес</label>
          <div class="relative">
            <input type="number" id="weight" step="0.1" placeholder="0.0" class="input-field w-full rounded-2xl px-4 py-3 text-2xl md:text-3xl font-extrabold" oninput="onWeightChange()">
            <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold text-sm">кг</div>
          </div>
        </div>
        <div>
          <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-2 block">СКФ</label>
          <div class="relative">
            <input type="number" id="egfr" step="1" placeholder=">60" class="input-field w-full rounded-2xl px-4 py-3 text-xl font-extrabold" oninput="calculate()">
            <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold text-[10px]">мл/мин</div>
          </div>
        </div>
        <div class="col-span-2 md:col-span-1">
          <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-2 block">Возрастная группа</label>
          <div id="age-group" class="grid grid-cols-3 gap-1">
            <button data-age="neonate" class="chip rounded-xl py-2 text-[10px]">Новор.<br><span class="text-[9px] opacity-70">0-28д</span></button>
            <button data-age="child" class="chip active rounded-xl py-2 text-[10px]">Дети<br><span class="text-[9px] opacity-70">1м-17л</span></button>
            <button data-age="adult" class="chip rounded-xl py-2 text-[10px]">Взр.<br><span class="text-[9px] opacity-70">&gt;18л</span></button>
          </div>
        </div>
      </div>
      <div id="weight-warn" class="hidden mt-3 text-[11px] font-bold text-red-600 bg-red-50 dark:bg-red-900/20 rounded-lg px-3 py-2"><i class="fas fa-exclamation-triangle mr-1"></i><span></span></div>
      <div id="renal-warn" class="hidden mt-2 text-[11px] font-bold text-amber-700 bg-amber-50 dark:bg-amber-900/20 dark:text-amber-400 rounded-lg px-3 py-2"><i class="fas fa-kidney mr-1"></i><span></span></div>
    </section>

    <section class="premium-card p-4 md:p-6 no-print">
      <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-3 block">2. Нозология (МКБ-10 / название)</label>
      <div class="relative">
        <i class="fas fa-search absolute left-4 md:left-5 top-1/2 -translate-y-1/2 text-slate-400"></i>
        <input type="text" id="search" placeholder="Поиск: отит, J18, пневмония, сифилис..." class="input-field w-full rounded-2xl py-3 md:py-4 pl-10 md:pl-12 pr-4 font-bold text-slate-700 text-sm" oninput="handleSearch()">
      </div>
      <div id="results-box" class="hidden mt-3 space-y-2 max-h-72 overflow-y-auto pr-1 scrollbar"></div>
      <div id="active-disease" class="hidden mt-4 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800 rounded-2xl">
        <div class="flex justify-between items-start">
          <div class="flex-1 min-w-0">
            <span id="active-title" class="font-bold text-blue-900 dark:text-blue-300 text-sm block mb-1"></span>
            <span id="active-mkb" class="text-[10px] font-black text-blue-400 uppercase"></span>
            <span id="active-cr" class="text-[10px] font-bold text-slate-400 ml-2"></span>
          </div>
          <button onclick="resetDisease()" class="text-blue-300 hover:text-red-500"><i class="fas fa-times-circle text-lg"></i></button>
        </div>
        <div id="active-indications" class="mt-2 text-[11px] text-blue-900/80 dark:text-blue-300/80 font-semibold"></div>
      </div>
    </section>

    <div id="scenario-step" class="hidden animate-in no-print">
      <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-3 ml-2 block">3. Клинический сценарий</label>
      <div id="scenario-list" class="space-y-2"></div>
    </div>

    <div id="drug-step" class="hidden animate-in no-print">
      <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-3 ml-2 block">4. Препарат (линии КР)</label>
      <div id="drug-list" class="space-y-2"></div>
    </div>

    <div id="form-step" class="hidden animate-in space-y-4 no-print">
      <section class="premium-card p-4 md:p-6">
        <div class="flex items-center justify-between mb-3">
          <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest">5. Лекарственная форма</label>
          <div id="route-tabs" class="flex gap-1"></div>
        </div>
        <div id="form-grid" class="grid grid-cols-2 md:grid-cols-3 gap-2"></div>

        <div id="regimen-selector" class="hidden mt-4 pt-4 border-t border-slate-100 dark:border-slate-700">
          <label class="text-[11px] font-black text-slate-400 uppercase tracking-widest mb-2 block">Режим дозирования</label>
          <div id="regimen-list" class="flex flex-wrap gap-2"></div>
        </div>
      </section>
    </div>

    <div id="result-step" class="hidden space-y-4 animate-in">

      <div class="no-print flex gap-2 flex-wrap">
        <button id="btn-copy" class="text-[10px] font-black uppercase tracking-widest text-blue-700 bg-blue-50 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-200 dark:border-blue-800 rounded-lg px-3 py-2 hover:bg-blue-100">
          <i class="fas fa-copy mr-1"></i>Копировать
        </button>
        <button id="btn-save-history" class="text-[10px] font-black uppercase tracking-widest text-emerald-700 bg-emerald-50 dark:bg-emerald-900/30 dark:text-emerald-300 border border-emerald-200 dark:border-emerald-800 rounded-lg px-3 py-2 hover:bg-emerald-100">
          <i class="fas fa-bookmark mr-1"></i>Сохранить
        </button>
        <button id="btn-print2" class="text-[10px] font-black uppercase tracking-widest text-slate-700 bg-slate-50 dark:bg-slate-800 dark:text-slate-300 border border-slate-200 dark:border-slate-700 rounded-lg px-3 py-2 hover:bg-slate-100">
          <i class="fas fa-print mr-1"></i>Печать
        </button>
      </div>

      <div id="res-po" class="hidden res-box rounded-[32px] p-6 md:p-8 text-white relative overflow-hidden">
        <p class="text-blue-100 text-[10px] font-black uppercase tracking-widest mb-2">Разовая доза (per os)</p>
        <div class="flex items-baseline gap-2 mb-5 flex-wrap">
          <span id="po-ml" class="text-5xl md:text-6xl font-black tracking-tighter italic">0.0</span>
          <span class="text-xl md:text-2xl font-bold text-blue-200" id="po-unit">мл</span>
          <span id="po-tabs" class="ml-auto text-sm md:text-base font-bold text-blue-200"></span>
        </div>
        <div class="bg-white/10 rounded-2xl p-4 md:p-5 mb-4 border border-white/10">
          <p id="po-instruction" class="text-sm md:text-base font-bold leading-snug"></p>
        </div>
        <div class="grid grid-cols-3 gap-3 md:gap-4 border-t border-white/10 pt-4 text-center">
          <div><p class="text-blue-200 text-[9px] font-black uppercase mb-1">Доза мг</p><p id="po-mg" class="text-base md:text-lg font-black"></p></div>
          <div><p class="text-blue-200 text-[9px] font-black uppercase mb-1">Сут. доза</p><p id="po-day" class="text-base md:text-lg font-black"></p></div>
          <div><p class="text-blue-200 text-[9px] font-black uppercase mb-1">Курс</p><p id="po-dur" class="text-base md:text-lg font-black italic"></p></div>
        </div>
        <div id="po-range" class="hidden mt-3 text-[11px] text-blue-100 font-semibold"></div>
        <div id="po-max-warn" class="hidden mt-2 text-[11px] font-bold bg-amber-500/20 text-amber-100 rounded-lg px-3 py-2"><i class="fas fa-exclamation-triangle mr-1"></i><span></span></div>
      </div>

      <div id="res-inj" class="hidden inj-box rounded-[32px] p-6 md:p-8 text-white relative overflow-hidden">
        <div class="flex justify-between items-start mb-4 flex-wrap gap-3">
          <div>
            <p class="text-orange-100 text-[10px] font-black uppercase tracking-widest mb-1">Разовая доза (<span id="inj-route-label">в/м</span>)</p>
            <div class="flex items-baseline gap-2">
              <span id="inj-mg" class="text-5xl md:text-6xl font-black tracking-tighter italic">0</span>
              <span class="text-xl md:text-2xl font-bold text-orange-200">мг</span>
            </div>
          </div>
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-3 md:p-4 text-center border border-white/10">
            <p class="text-[9px] text-orange-100 font-black uppercase mb-1">Кратность</p>
            <p id="inj-freq" class="text-lg md:text-xl font-black">1 р/д</p>
          </div>
        </div>
        <div class="bg-white/10 rounded-2xl p-4 md:p-5 mb-4 border border-white/10">
          <p id="inj-instruction" class="text-sm md:text-base font-bold leading-snug"></p>
        </div>
        <div class="grid grid-cols-3 gap-3 md:gap-4 border-t border-white/10 pt-4 text-center">
          <div><p class="text-orange-200 text-[9px] font-black uppercase mb-1">Объём р-ра</p><p id="inj-ml" class="text-base md:text-lg font-black"></p></div>
          <div><p class="text-orange-200 text-[9px] font-black uppercase mb-1">Сут. доза</p><p id="inj-day" class="text-base md:text-lg font-black"></p></div>
          <div><p class="text-orange-200 text-[9px] font-black uppercase mb-1">Курс</p><p id="inj-dur" class="text-base md:text-lg font-black italic"></p></div>
        </div>
        <div id="inj-range" class="hidden mt-3 text-[11px] text-orange-100 font-semibold"></div>
        <div id="inj-max-warn" class="hidden mt-2 text-[11px] font-bold bg-amber-500/20 text-amber-100 rounded-lg px-3 py-2"><i class="fas fa-exclamation-triangle mr-1"></i><span></span></div>
      </div>

      <div id="combo-block" class="hidden space-y-3"></div>

      <div id="reconstitution-block" class="hidden premium-card p-4 md:p-6">
        <div class="flex items-center gap-2 mb-3">
          <i class="fas fa-flask text-blue-600 text-lg"></i>
          <h3 class="text-base font-black text-slate-800 dark:text-slate-200">Приготовление суспензии</h3>
        </div>
        <div id="reconstitution-content" class="text-xs space-y-2"></div>
      </div>

      <div id="dilution-block" class="hidden premium-card p-4 md:p-6">
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          <i class="fas fa-syringe text-orange-600 text-lg"></i>
          <h3 class="text-base font-black text-slate-800 dark:text-slate-200">Приготовление и введение</h3>
          <div id="route-selector" class="ml-auto flex gap-1"></div>
        </div>

        <div id="vial-selector" class="mb-4 hidden">
          <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block">Размер флакона</label>
          <div id="vial-list" class="flex flex-wrap gap-2"></div>
        </div>

        <div id="dilution-warn" class="hidden mb-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-2xl p-3">
          <p class="text-[10px] font-black text-red-600 dark:text-red-400 uppercase tracking-widest mb-1"><i class="fas fa-exclamation-circle mr-1"></i>Внимание</p>
          <p id="dilution-warn-text" class="text-xs text-red-900 dark:text-red-300 font-semibold"></p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3" id="dilution-solvents"></div>

        <div id="dilution-cautions" class="hidden mb-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-2xl p-3">
          <p class="text-[10px] font-black text-amber-700 dark:text-amber-400 uppercase tracking-widest mb-1"><i class="fas fa-triangle-exclamation mr-1"></i>Особые указания</p>
          <p id="dilution-cautions-text" class="text-xs text-amber-900 dark:text-amber-300 font-semibold"></p>
        </div>

        <div>
          <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Пошаговая инструкция</p>
          <ol id="dilution-steps" class="steps"></ol>
        </div>
      </div>

      <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-100 dark:border-amber-800 rounded-3xl p-4 md:p-6 flex gap-4">
        <div class="w-10 h-10 bg-amber-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
          <i class="fas fa-exclamation-triangle text-amber-600"></i>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-[10px] font-black text-amber-600 dark:text-amber-400 uppercase tracking-widest mb-1">Клиническое замечание</p>
          <p id="res-note" class="text-xs text-amber-900 dark:text-amber-300 leading-relaxed font-semibold italic"></p>
        </div>
      </div>

      <div id="drug-meta" class="premium-card p-4 md:p-5 text-xs space-y-2"></div>

    </div>

    <div id="empty-state" class="text-center py-12 opacity-40 no-print">
      <i class="fas fa-stethoscope text-5xl mb-3"></i>
      <p class="text-sm font-bold">Выберите нозологию для расчёта</p>
      <p class="text-[10px] mt-2">46 нозологий • 28 препаратов • КР МЗ РФ</p>
    </div>

  </div>

  <footer class="mt-8 md:mt-12 text-center text-[9px] text-slate-400 font-black uppercase tracking-[0.2em] space-y-1 no-print">
    <p id="verification-status">ЧЕРНОВИК • Требует верификации по первоисточникам КР МЗ РФ</p>
    <p>Verified by Arena Medical Agent • 2026</p>
  </footer>
</div>

<div id="drawer-overlay" class="drawer-overlay no-print"></div>
<div id="history-drawer" class="drawer no-print">
  <div class="p-4 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center">
    <h3 class="font-black text-slate-800 dark:text-white"><i class="fas fa-history mr-2 text-blue-600"></i>История расчётов</h3>
    <button id="drawer-close" class="text-slate-400 hover:text-red-500"><i class="fas fa-times text-lg"></i></button>
  </div>
  <div id="history-list" class="p-4 space-y-2"></div>
  <div class="p-4 border-t border-slate-100 dark:border-slate-700">
    <button id="history-clear" class="text-[10px] font-black uppercase tracking-widest text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg px-3 py-2 w-full"><i class="fas fa-trash mr-1"></i>Очистить историю</button>
  </div>
</div>

<div class="mobile-nav hidden md:hidden fixed bottom-0 left-0 right-0 bg-white dark:bg-slate-800 border-t border-slate-100 dark:border-slate-700 px-2 py-2 justify-around no-print z-50" style="display:none">
  <button onclick="document.getElementById('search').focus()" class="flex flex-col items-center text-slate-500 dark:text-slate-400 text-[10px] font-bold"><i class="fas fa-search mb-1"></i>Поиск</button>
  <button onclick="document.getElementById('btn-history').click()" class="flex flex-col items-center text-slate-500 dark:text-slate-400 text-[10px] font-bold"><i class="fas fa-history mb-1"></i>История</button>
  <button onclick="document.getElementById('btn-copy').click()" class="flex flex-col items-center text-slate-500 dark:text-slate-400 text-[10px] font-bold"><i class="fas fa-copy mb-1"></i>Копир</button>
  <button onclick="document.getElementById('btn-print').click()" class="flex flex-col items-center text-slate-500 dark:text-slate-400 text-[10px] font-bold"><i class="fas fa-print mb-1"></i>Печать</button>
  <button onclick="document.getElementById('btn-theme').click()" class="flex flex-col items-center text-slate-500 dark:text-slate-400 text-[10px] font-bold"><i class="fas fa-moon mb-1" id="theme-icon-m"></i>Тема</button>
</div>

<div id="toast" class="toast"></div>

<script id="db-data" type="application/json">__DB_PLACEHOLDER__</script>
<script>
let DB = null;
let activeDisease = null, activeScenario = null, activeLine = null, activeDrug = null, activeFormIdx = 0, activeRegimenIdx = 0, activeRouteKey = null, activeVialIdx = 0;
let activeAge = 'child';
let userPickedAge = false;
let currentRouteGroup = 'all';

function $(id){return document.getElementById(id);}
function toast(msg){
  const t = $('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._timer);
  t._timer = setTimeout(()=>t.classList.remove('show'), 2500);
}
function init(){
  try{
    const raw = $('db-data').textContent.trim();
    DB = JSON.parse(raw);
    document.getElementById('verification-status').textContent = (DB.meta.verification_status||'draft').toUpperCase()+' • '+DB.meta.warning;
    document.getElementById('header-stats').textContent = 'КР МЗ РФ • '+DB.recommendations.length+' нозологий • '+Object.keys(DB.drugs_reference).filter(k=>k!=='_note').length+' препаратов';
  }catch(e){
    $('empty-state').innerHTML = '<p class="text-red-600 font-bold">Ошибка загрузки БД: '+e.message+'</p>';
    return;
  }
  document.querySelectorAll('#age-group button').forEach(b=>{
    b.onclick = ()=>{
      document.querySelectorAll('#age-group button').forEach(x=>x.classList.remove('active'));
      b.classList.add('active');
      activeAge = b.dataset.age;
      userPickedAge = true;
      if(activeDisease) renderScenarios();
      calculate();
    };
  });
  setupButtons();
  setupTheme();
  loadHistory();
  if(window.location.hash){
    setTimeout(restoreFromHash, 100);
  }
}
function setupButtons(){
  $('btn-print').onclick = ()=>window.print();
  $('btn-print2').onclick = ()=>window.print();
  $('btn-copy').onclick = copyPrescription;
  $('btn-save-history').onclick = saveToHistory;
  $('btn-history').onclick = openHistory;
  $('btn-theme').onclick = toggleTheme;
  $('drawer-close').onclick = closeHistory;
  $('drawer-overlay').onclick = closeHistory;
  $('history-clear').onclick = clearHistory;
  document.querySelector('.mobile-nav').style.display = (window.innerWidth < 768) ? 'flex' : 'none';
  window.addEventListener('resize', ()=>{
    document.querySelector('.mobile-nav').style.display = (window.innerWidth < 768) ? 'flex' : 'none';
  });
}
function setupTheme(){
  const saved = localStorage.getItem('antibio_theme');
  if(saved === 'dark'){
    document.documentElement.classList.add('dark');
    $('theme-icon').className = 'fas fa-sun';
    const m = $('theme-icon-m'); if(m) m.className = 'fas fa-sun mb-1';
  }
}
function toggleTheme(){
  document.documentElement.classList.toggle('dark');
  const isDark = document.documentElement.classList.contains('dark');
  localStorage.setItem('antibio_theme', isDark ? 'dark' : 'light');
  $('theme-icon').className = isDark ? 'fas fa-sun' : 'fas fa-moon';
  const m = $('theme-icon-m'); if(m) m.className = (isDark ? 'fas fa-sun' : 'fas fa-moon') + ' mb-1';
}
function onWeightChange(){
  const w = parseFloat($('weight').value);
  const warn = $('weight-warn');
  if(!w){ warn.classList.add('hidden'); calculate(); return; }
  let msg = '';
  if(w < 1) msg = 'Вес <1 кг — вероятно ошибка. Расчёт для новорождённых требует осмотр врача.';
  else if(w > 250) msg = 'Вес >250 кг — проверьте значение.';
  else if(w < 40 && activeAge === 'adult') msg = 'Вес <40 кг, выбрана группа "взрослые". Возможно стоит переключить на "дети".';
  if(msg){ warn.querySelector('span').textContent = msg; warn.classList.remove('hidden'); }
  else warn.classList.add('hidden');
  if(!userPickedAge){
    if(w > 0 && w < 40 && activeAge !== 'neonate') setActiveAge('child');
    else if(w >= 40 && activeAge === 'child') setActiveAge('adult');
  }
  calculate();
}
function setActiveAge(a){
  activeAge = a;
  document.querySelectorAll('#age-group button').forEach(b=>{
    b.classList.toggle('active', b.dataset.age === a);
  });
}
function handleSearch(){
  const q = $('search').value.toLowerCase().trim();
  const box = $('results-box');
  if(q.length < 2){ box.classList.add('hidden'); return; }
  const filtered = DB.recommendations.filter(d=>{
    if(d.mkb10.some(m=>m.toLowerCase().includes(q))) return true;
    if(d.name.toLowerCase().includes(q)) return true;
    if(d.synonyms && d.synonyms.some(s=>s.toLowerCase().includes(q))) return true;
    return false;
  });
  box.innerHTML = '';
  filtered.forEach(d=>{
    const item = document.createElement('div');
    item.className = 'bg-white dark:bg-slate-800 p-3 rounded-xl border border-slate-100 dark:border-slate-700 cursor-pointer hover:bg-blue-50 dark:hover:bg-slate-700 transition-all font-bold text-slate-700 dark:text-slate-200 text-sm flex justify-between items-center';
    item.innerHTML = '<div class="min-w-0"><div>'+d.name+'</div><div class="text-[10px] text-slate-400 font-normal mt-0.5">МКБ: '+d.mkb10.slice(0,3).join(', ')+(d.mkb10.length>3?'…':'')+'</div></div><span class="text-blue-500 text-xs ml-2">'+d.mkb10[0]+'</span>';
    item.onclick = ()=>selectDisease(d);
    box.appendChild(item);
  });
  box.classList.toggle('hidden', filtered.length === 0);
}
function selectDisease(d){
  activeDisease = d;
  $('results-box').classList.add('hidden');
  $('search').value = '';
  $('active-disease').classList.remove('hidden');
  $('active-title').textContent = d.name;
  $('active-mkb').textContent = 'МКБ-10: '+d.mkb10.join(', ');
  $('active-cr').textContent = 'КР #'+d.cr_id+' • '+d.cr_year;
  $('active-indications').textContent = d.indications ? 'Показания: '+d.indications.join('; ') : '';
  $('empty-state').classList.add('hidden');
  $('scenario-step').classList.remove('hidden');
  $('drug-step').classList.add('hidden');
  $('form-step').classList.add('hidden');
  $('result-step').classList.add('hidden');
  renderScenarios();
  updateHash();
}
function resetDisease(){
  activeDisease = null; activeScenario = null; activeDrug = null;
  $('active-disease').classList.add('hidden');
  $('scenario-step').classList.add('hidden');
  $('drug-step').classList.add('hidden');
  $('form-step').classList.add('hidden');
  $('result-step').classList.add('hidden');
  $('empty-state').classList.remove('hidden');
  history.replaceState(null, '', window.location.pathname);
}
function renderScenarios(){
  const list = $('scenario-list');
  list.innerHTML = '';
  let firstVisible = null;
  activeDisease.scenarios.forEach((s, idx)=>{
    const ageMatch = s.age_group === 'all' || s.age_group === activeAge;
    const card = document.createElement('div');
    card.className = 'scenario-card drug-card premium-card p-3 md:p-4'+(ageMatch?'':' opacity-50');
    card.dataset.idx = idx;
    card.innerHTML = '<div class="flex justify-between items-center"><div><div class="font-bold text-slate-800 dark:text-slate-200 text-sm">'+s.name+'</div>'+(ageMatch?'':'<div class="text-[10px] text-red-500 font-bold mt-1">Не подходит для выбранной возрастной группы</div>')+'</div><i class="fas fa-chevron-right text-slate-300"></i></div>';
    card.onclick = ()=>selectScenario(s, card);
    list.appendChild(card);
    if(ageMatch && !firstVisible) firstVisible = s;
  });
  if(firstVisible) selectScenario(firstVisible, list.querySelector('.scenario-card.active') || list.firstChild);
}
function selectScenario(s, card){
  activeScenario = s;
  document.querySelectorAll('#scenario-list .scenario-card').forEach(c=>c.classList.remove('active'));
  if(card) card.classList.add('active');
  $('drug-step').classList.remove('hidden');
  renderLines();
  updateHash();
}
function renderLines(){
  const list = $('drug-list');
  list.innerHTML = '';
  activeScenario.lines.forEach((line, lineIdx)=>{
    line.drugs.forEach((drug, drugIdx)=>{
      const isCombo = !!drug.combo_ref;
      const refs = isCombo ? drug.combo_ref : [drug.drug_ref];
      const names = refs.map(r=>(DB.drugs_reference[r]&&DB.drugs_reference[r].inn)||r).join(' + ');
      const lineCls = line.line_number === 1 ? 'line-1' : (line.line_number === 2 ? 'line-2' : 'line-0');
      const lineLabel = line.line_number === 1 ? 'Линия 1' : (line.line_number === 2 ? 'Линия 2' : 'Альт.');
      const card = document.createElement('div');
      card.className = 'drug-card premium-card p-3 md:p-4 flex justify-between items-center';
      card.dataset.lineIdx = lineIdx;
      card.dataset.drugIdx = drugIdx;
      card.innerHTML = '<div class="min-w-0 flex-1"><div class="font-bold text-slate-800 dark:text-slate-200 text-sm">'+names+'</div>'+(drug.indication_note?'<div class="text-[11px] text-slate-500 dark:text-slate-400 font-semibold mt-0.5">'+drug.indication_note+'</div>':'')+(line.combo_therapy?'<div class="text-[10px] text-blue-600 font-black mt-1 uppercase tracking-widest"><i class="fas fa-link mr-1"></i>комбинированная терапия</div>':'')+'</div><span class="badge '+lineCls+' bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 ml-2" style="border:1px solid">'+lineLabel+'</span>';
      card.onclick = ()=>selectDrug(drug, line, card);
      list.appendChild(card);
    });
  });
  const first = list.querySelector('.drug-card');
  if(first) first.click();
}
function selectDrug(drug, line, card){
  activeDrug = drug; activeLine = line; activeFormIdx = 0; activeRegimenIdx = 0; activeRouteKey = null; activeVialIdx = 0;
  document.querySelectorAll('#drug-list .drug-card').forEach(c=>c.classList.remove('active'));
  card.classList.add('active');
  $('form-step').classList.remove('hidden');
  $('result-step').classList.remove('hidden');
  renderForms();
  renderRegimens();
  calculate();
  updateHash();
}
function getDrugRefs(drug){
  if(drug.combo_ref) return drug.combo_ref;
  return [drug.drug_ref];
}
function renderForms(){
  const refs = getDrugRefs(activeDrug);
  const mainRef = DB.drugs_reference[refs[0]];
  if(!mainRef) return;
  const forms = mainRef.forms || [];
  const grid = $('form-grid');
  grid.innerHTML = '';
  const routeTabs = $('route-tabs');
  routeTabs.innerHTML = '';

  const groups = {po:[], im:[], iv:[]};
  forms.forEach((f, idx)=>{
    if(['tablet','capsule','suspension','syrup','granules'].includes(f.form_type)){
      groups.po.push({f, idx});
    } else if(mainRef.dilution && mainRef.dilution.im && ['powder_for_suspension','solution_im'].includes(f.form_type)){
      groups.im.push({f, idx});
    } else if(mainRef.dilution && (mainRef.dilution.iv_bolus || mainRef.dilution.iv_infusion) && ['powder_for_suspension','solution_iv'].includes(f.form_type)){
      groups.iv.push({f, idx});
    } else {
      groups.po.push({f, idx});
    }
  });

  const groupKeys = Object.keys(groups).filter(k=>groups[k].length>0);
  if(groupKeys.length === 0) return;

  currentRouteGroup = groupKeys[0];
  groupKeys.forEach(k=>{
    const tab = document.createElement('button');
    tab.className = 'route-tab chip text-[10px] font-black uppercase rounded-lg px-2 py-1'+(k===currentRouteGroup?' active':'');
    const label = k==='po'?'per os':(k==='im'?'в/м':'в/в');
    tab.textContent = label;
    tab.onclick = ()=>{
      currentRouteGroup = k;
      routeTabs.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
      tab.classList.add('active');
      renderFormChips(groups[k]);
      calculate();
    };
    routeTabs.appendChild(tab);
  });
  renderFormChips(groups[currentRouteGroup]);
}
function renderFormChips(group){
  const grid = $('form-grid');
  grid.innerHTML = '';
  if(group.length === 0){ grid.innerHTML = '<p class="text-xs text-slate-400">Нет форм для этого пути</p>'; return; }
  group.forEach((entry, i)=>{
    const f = entry.f;
    const idx = entry.idx;
    const btn = document.createElement('button');
    btn.className = 'chip rounded-xl py-2 md:py-3 px-2 text-[10px] font-black uppercase tracking-wider text-left'+(i===0?' active':'');
    let routeIcon = 'fa-pill';
    if(f.form_type === 'tablet' || f.form_type === 'capsule') routeIcon = 'fa-pills';
    else if(['powder_for_suspension','suspension','syrup'].includes(f.form_type)) routeIcon = 'fa-flask';
    else if(f.form_type === 'solution_iv') routeIcon = 'fa-drip';
    else if(f.form_type === 'solution_im') routeIcon = 'fa-syringe';
    else if(f.form_type === 'granules') routeIcon = 'fa-prescription-bottle';
    btn.innerHTML = '<i class="fas '+routeIcon+' mr-1"></i><div>'+f.concentration+'</div>'+(f.notes?'<div class="text-[8px] font-bold opacity-70 mt-0.5 normal-case">'+f.notes+'</div>':'');
    btn.onclick = ()=>{
      activeFormIdx = idx;
      grid.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      calculate();
    };
    grid.appendChild(btn);
  });
  activeFormIdx = group[0].idx;
}
function renderRegimens(){
  const refs = getDrugRefs(activeDrug);
  const mainRef = DB.drugs_reference[refs[0]];
  const regimens = (activeDrug.regimens || []).filter(r=>r.age_group === activeAge || r.age_group === 'all');
  const sel = $('regimen-selector');
  const list = $('regimen-list');
  list.innerHTML = '';
  if(regimens.length > 1){
    sel.classList.remove('hidden');
    regimens.forEach((r, idx)=>{
      const btn = document.createElement('button');
      btn.className = 'chip text-[10px] font-black rounded-lg px-3 py-2'+(idx===0?' active':'');
      const label = r.regimen_label || ((r.dose_mg_kg_day?r.dose_mg_kg_day+' мг/кг':'')+' '+(r.freq_per_day?r.freq_per_day+' р/д':''));
      btn.textContent = label;
      btn.onclick = ()=>{
        activeRegimenIdx = idx;
        list.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
        calculate();
      };
      list.appendChild(btn);
    });
    activeRegimenIdx = 0;
  } else {
    sel.classList.add('hidden');
    activeRegimenIdx = 0;
  }
}
function getActiveRegimen(){
  if(!activeDrug) return null;
  const regimens = (activeDrug.regimens || []).filter(r=>r.age_group === activeAge || r.age_group === 'all');
  if(regimens.length === 0){
    return (activeDrug.regimens || [])[0];
  }
  return regimens[activeRegimenIdx] || regimens[0];
}
function computeDose(reg, w){
  let singleMg = 0, dailyMg = 0, capped = false;
  if(reg.dose_mg_kg_day != null && w > 0){
    dailyMg = w * reg.dose_mg_kg_day;
  } else if(reg.dose_mg_day_fixed != null){
    dailyMg = reg.dose_mg_day_fixed;
  } else if(reg.single_dose_mg != null){
    singleMg = reg.single_dose_mg;
    dailyMg = singleMg * reg.freq_per_day;
  }
  if(reg.max_daily_mg != null && dailyMg > reg.max_daily_mg){
    dailyMg = reg.max_daily_mg;
    capped = true;
  }
  if(singleMg === 0) singleMg = dailyMg / reg.freq_per_day;
  return {singleMg, dailyMg, capped};
}
function calculate(){
  if(!activeDrug) return;
  const w = parseFloat($('weight').value);
  const refs = getDrugRefs(activeDrug);
  const mainRef = DB.drugs_reference[refs[0]];
  if(!mainRef) return;
  const form = mainRef.forms[activeFormIdx];
  const reg = getActiveRegimen();
  if(!reg) return;
  const {singleMg, dailyMg, capped} = computeDose(reg, w);

  $('combo-block').classList.add('hidden');
  $('combo-block').innerHTML = '';

  const isPO = currentRouteGroup === 'po';
  const isInj = currentRouteGroup === 'im' || currentRouteGroup === 'iv';

  if(isPO){
    $('res-po').classList.remove('hidden');
    $('res-inj').classList.add('hidden');
    $('dilution-block').classList.add('hidden');
    renderPO(reg, form, mainRef, w, singleMg, dailyMg, capped);
    renderReconstitution(form);
  } else if(isInj){
    $('res-po').classList.add('hidden');
    $('res-inj').classList.remove('hidden');
    $('dilution-block').classList.remove('hidden');
    $('reconstitution-block').classList.add('hidden');
    renderInjection(reg, form, mainRef, w, singleMg, dailyMg, capped);
  }

  if(refs.length > 1){
    renderComboComponents(refs.slice(1), reg, w);
  }

  $('res-note').textContent = activeDrug.indication_note || (activeLine && activeLine.line_label) || '';
  renderDrugMeta(mainRef, reg);
  renderRenalWarning(mainRef);
}
function renderPO(reg, form, ref, w, singleMg, dailyMg, capped){
  const concMgPerMl = form.concentration_mg_per_ml || 0;
  const isSolid = ['tablet','capsule'].includes(form.form_type);
  if(isSolid || (w >= 40 && concMgPerMl === 0)){
    $('po-ml').textContent = Math.round(singleMg);
    $('po-unit').textContent = 'мг';
    $('po-tabs').textContent = formatTablets(singleMg, form);
    $('po-instruction').innerHTML = '<i class="fas fa-pills mr-2 text-blue-300"></i>Принимать по <b>'+Math.round(singleMg)+' мг</b> '+reg.freq_per_day+' р/д '+(form.concentration||'');
  } else {
    const ml = concMgPerMl > 0 ? singleMg / concMgPerMl : 0;
    $('po-ml').textContent = ml.toFixed(1);
    $('po-unit').textContent = 'мл';
    $('po-tabs').textContent = '';
    $('po-instruction').innerHTML = '<i class="fas fa-flask mr-2 text-blue-300"></i>Давать по <b>'+ml.toFixed(1)+' мл</b> суспензии ('+form.concentration+') '+reg.freq_per_day+' р/д';
  }
  $('po-mg').textContent = Math.round(singleMg)+' мг';
  $('po-day').textContent = Math.round(dailyMg)+' мг';
  $('po-dur').textContent = reg.duration_days || '—';

  const rangeEl = $('po-range');
  if(reg.dose_range_mg_kg_day && reg.dose_range_mg_kg_day.length === 2){
    rangeEl.classList.remove('hidden');
    rangeEl.textContent = 'Диапазон по КР: '+reg.dose_range_mg_kg_day[0]+'-'+reg.dose_range_mg_kg_day[1]+' мг/кг/сут';
  } else if(reg.dose_mg_kg_day){
    rangeEl.classList.remove('hidden');
    rangeEl.textContent = 'Доза по КР: '+reg.dose_mg_kg_day+' мг/кг/сут';
  } else rangeEl.classList.add('hidden');

  const warnEl = $('po-max-warn');
  if(capped){
    warnEl.querySelector('span').textContent = 'Превышена max суточная доза — снижено до '+reg.max_daily_mg+' мг/сут';
    warnEl.classList.remove('hidden');
  } else warnEl.classList.add('hidden');
}
function formatTablets(mg, form){
  if(!['tablet','capsule'].includes(form.form_type)) return '';
  const m = form.concentration.match(/(\d+)\s*мг/);
  if(!m) return '';
  const strength = parseInt(m[1]);
  if(strength <= 0) return '';
  const tabs = mg / strength;
  if(tabs === Math.round(tabs)) return '('+tabs+' таб '+strength+' мг)';
  const half = Math.round(tabs*2)/2;
  return '(~'+half+' таб '+strength+' мг)';
}
function renderReconstitution(form){
  const block = $('reconstitution-block');
  const content = $('reconstitution-content');
  if(form.reconstitution){
    block.classList.remove('hidden');
    const r = form.reconstitution;
    let html = '<div class="font-bold text-slate-800 dark:text-slate-200 mb-1">Приготовление '+form.concentration+':</div>';
    html += '<div class="text-slate-600 dark:text-slate-400 mb-2">Растворитель: <b>'+r.solvent+'</b> — '+r.solvent_ml+' мл (итог: '+r.final_volume_ml+' мл)</div>';
    html += '<ol class="steps">';
    r.steps.forEach(s=>{ html += '<li class="step"><span>'+s+'</span></li>'; });
    html += '</ol>';
    if(r.storage) html += '<div class="mt-2 text-amber-700 dark:text-amber-400 font-bold bg-amber-50 dark:bg-amber-900/20 rounded-lg px-3 py-2"><i class="fas fa-snowflake mr-1"></i>'+r.storage+'</div>';
    content.innerHTML = html;
  } else {
    block.classList.add('hidden');
  }
}
function renderInjection(reg, form, ref, w, singleMg, dailyMg, capped){
  const dil = ref.dilution;
  let availableRoutes = [];
  if(dil.im && currentRouteGroup === 'im') availableRoutes.push('im');
  if((dil.iv_bolus || dil.iv_infusion) && currentRouteGroup === 'iv'){
    if(dil.iv_bolus) availableRoutes.push('iv_bolus');
    if(dil.iv_infusion) availableRoutes.push('iv_infusion');
  }
  if(availableRoutes.length === 0){
    if(dil.im) availableRoutes.push('im');
    else if(dil.iv_bolus) availableRoutes.push('iv_bolus');
    else if(dil.iv_infusion) availableRoutes.push('iv_infusion');
  }
  if(!activeRouteKey || !availableRoutes.includes(activeRouteKey)) activeRouteKey = availableRoutes[0];

  const routeSel = $('route-selector');
  routeSel.innerHTML = '';
  availableRoutes.forEach(k=>{
    const btn = document.createElement('button');
    btn.className = 'chip text-[10px] font-black uppercase rounded-lg px-2 py-1'+(k===activeRouteKey?' active':'');
    btn.textContent = routeKeyLabel(k);
    btn.onclick = ()=>{
      activeRouteKey = k; activeVialIdx = 0;
      routeSel.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      renderInjection(reg, form, ref, w, singleMg, dailyMg, capped);
    };
    routeSel.appendChild(btn);
  });

  const routeData = dil[activeRouteKey];
  $('inj-route-label').textContent = routeKeyLabel(activeRouteKey);
  $('inj-mg').textContent = Math.round(singleMg);
  $('inj-freq').textContent = reg.freq_per_day+' р/д';

  let selectedVial = null;
  if(routeData.solvent_options && routeData.solvent_options.length > 0){
    const vials = routeData.solvent_options;
    if(activeVialIdx >= vials.length) activeVialIdx = 0;
    selectedVial = vials[activeVialIdx];
    const vialSel = $('vial-selector');
    const vialList = $('vial-list');
    vialList.innerHTML = '';
    vials.forEach((v, idx)=>{
      const btn = document.createElement('button');
      btn.className = 'chip text-[10px] font-black rounded-lg px-2 py-1'+(idx===activeVialIdx?' active':'');
      const label = v.vial_mg ? v.vial_mg+' мг' : (v.vial_units ? formatUnits(v.vial_units)+' ЕД' : v.solvent);
      btn.textContent = label;
      btn.onclick = ()=>{
        activeVialIdx = idx;
        vialList.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
        renderInjection(reg, form, ref, w, singleMg, dailyMg, capped);
      };
      vialList.appendChild(btn);
    });
    vialSel.classList.toggle('hidden', vials.length <= 1);
  } else {
    $('vial-selector').classList.add('hidden');
  }

  $('inj-ml').textContent = computeInjectableMl(singleMg, selectedVial);
  $('inj-day').textContent = Math.round(dailyMg)+' мг';
  $('inj-dur').textContent = reg.duration_days || '—';
  $('inj-instruction').innerHTML = '<i class="fas fa-syringe mr-2 text-orange-300"></i>Ввести <b>'+Math.round(singleMg)+' мг</b> '+routeKeyLabel(activeRouteKey)+' • '+reg.freq_per_day+' р/д';

  const rangeEl = $('inj-range');
  if(reg.dose_mg_kg_day){
    rangeEl.classList.remove('hidden');
    rangeEl.textContent = 'Доза по КР: '+reg.dose_mg_kg_day+' мг/кг/сут';
  } else rangeEl.classList.add('hidden');

  const warnEl = $('inj-max-warn');
  if(capped){
    warnEl.querySelector('span').textContent = 'Превышена max суточная доза — снижено до '+reg.max_daily_mg+' мг/сут';
    warnEl.classList.remove('hidden');
  } else warnEl.classList.add('hidden');

  renderDilutionBlock(ref, activeRouteKey, singleMg, selectedVial, routeData);
}
function routeKeyLabel(k){
  return k === 'im' ? 'в/м' : (k === 'iv_bolus' ? 'в/в струйно' : 'в/в капельно');
}
function computeInjectableMl(singleMg, vial){
  if(!vial) return '—';
  const conc = vial.final_concentration_mg_ml || vial.final_concentration_units_ml || 0;
  if(conc <= 0) return '—';
  const isUnits = !!vial.final_concentration_units_ml;
  const ml = singleMg / conc;
  return ml.toFixed(2)+' мл';
}
function renderDilutionBlock(ref, routeKey, singleMg, selectedVial, routeData){
  const warn = $('dilution-warn');
  const warnText = $('dilution-warn-text');
  let warnings = [];
  if(routeData.child_solvent_warning && activeAge !== 'adult') warnings.push(routeData.child_solvent_warning);
  if(routeData.contraindications) warnings.push(routeData.contraindications);
  if(ref.interactions && ref.interactions.indexOf('Ca')>=0 && routeKey !== 'im') warnings.push('Не смешивать с Ca-растворами.');
  if(warnings.length){
    warnText.innerHTML = warnings.join('<br><br>');
    warn.classList.remove('hidden');
  } else warn.classList.add('hidden');

  const solBox = $('dilution-solvents');
  solBox.innerHTML = '';
  if(selectedVial){
    const div = document.createElement('div');
    div.className = 'dilution-solvent';
    const vial = selectedVial.vial_mg ? selectedVial.vial_mg+' мг' : (selectedVial.vial_units ? formatUnits(selectedVial.vial_units)+' ЕД' : '');
    const conc = selectedVial.final_concentration_mg_ml ? selectedVial.final_concentration_mg_ml+' мг/мл' : (selectedVial.final_concentration_units_ml ? formatUnits(selectedVial.final_concentration_units_ml)+' ЕД/мл' : '');
    const mlForDose = (selectedVial.final_concentration_mg_ml || selectedVial.final_concentration_units_ml) ? (singleMg / (selectedVial.final_concentration_mg_ml || selectedVial.final_concentration_units_ml)).toFixed(2)+' мл' : '';
    div.innerHTML = '<div class="font-black text-orange-700 dark:text-orange-400 mb-1">'+selectedVial.solvent+'</div><div>Флакон: '+vial+'</div><div>Растворитель: '+selectedVial.solvent_ml+' мл</div><div>Итог: '+selectedVial.final_volume_ml+' мл, '+conc+'</div>'+(mlForDose?'<div class="mt-1 text-orange-900 dark:text-orange-300 font-black">На дозу: '+mlForDose+'</div>':'')+(selectedVial.notes?'<div class="mt-1 text-[10px] italic opacity-80">'+selectedVial.notes+'</div>':'');
    solBox.appendChild(div);
  }

  const caut = $('dilution-cautions');
  if(routeData.cautions){
    $('dilution-cautions-text').textContent = routeData.cautions;
    caut.classList.remove('hidden');
  } else caut.classList.add('hidden');

  const stepsEl = $('dilution-steps');
  stepsEl.innerHTML = '';
  (routeData.steps || []).forEach(s=>{
    const li = document.createElement('li');
    li.className = 'step';
    li.innerHTML = '<span>'+s.replace(/^\d+\.\s*/, '')+'</span>';
    stepsEl.appendChild(li);
  });
}
function renderComboComponents(refs, reg, w){
  if(refs.length === 0) return;
  const block = $('combo-block');
  block.classList.remove('hidden');
  block.innerHTML = '<div class="text-[11px] font-black text-slate-400 uppercase tracking-widest ml-2">Компоненты комбинации</div>';
  refs.forEach(refKey=>{
    const ref = DB.drugs_reference[refKey];
    if(!ref) return;
    const comboReg = reg;
    const {singleMg, dailyMg} = computeDose(comboReg, w);
    const card = document.createElement('div');
    card.className = 'premium-card p-4 text-sm';
    card.innerHTML = '<div class="font-bold text-slate-800 dark:text-slate-200 mb-1">'+ref.inn+'</div><div class="text-xs text-slate-600 dark:text-slate-400">Доза применяется согласно основному режиму линии.</div>';
    block.appendChild(card);
  });
}
function formatUnits(n){
  if(n >= 1000000) return (n/1000000).toString().replace('.0','')+' млн';
  if(n >= 1000) return (n/1000).toString().replace('.0','')+' тыс';
  return n.toString();
}
function renderDrugMeta(ref, reg){
  const meta = $('drug-meta');
  const renal = ref.renal_adjustment || '—';
  const hepatic = ref.hepatic_adjustment || '—';
  const preg = ref.pregnancy_category || '—';
  const mon = ref.monitoring || '—';
  const inter = ref.interactions || '—';
  const stor = ref.storage_reconstituted || '—';
  const cr = activeDisease ? 'КР #'+activeDisease.cr_id+' • '+activeDisease.cr_year : '';
  const url = activeDisease ? activeDisease.source_url : '';
  meta.innerHTML = ''
    + metaRow('МНН', ref.inn)
    + metaRow('Класс', ref.class || '—')
    + metaRow('Коррекция по почкам', renal)
    + metaRow('Коррекция по печени', hepatic)
    + metaRow('Беременность', preg)
    + metaRow('Мониторинг', mon)
    + metaRow('Взаимодействия', inter)
    + metaRow('Хранение', stor)
    + metaRow('Источник', cr+(url?' — '+url:''));
}
function metaRow(k, v){
  return '<div class="flex justify-between gap-3"><span class="text-slate-400 dark:text-slate-500 font-black uppercase text-[10px] tracking-widest flex-shrink-0">'+k+'</span><span class="text-slate-700 dark:text-slate-300 font-semibold text-right">'+v+'</span></div>';
}
function renderRenalWarning(ref){
  const egfr = parseFloat($('egfr').value);
  const warn = $('renal-warn');
  if(!egfr || egfr > 60 || !ref.renal_adjustment){
    warn.classList.add('hidden');
    return;
  }
  warn.querySelector('span').textContent = 'СКФ '+egfr+' мл/мин — требуется коррекция дозы: '+ref.renal_adjustment;
  warn.classList.remove('hidden');
}
function copyPrescription(){
  if(!activeDrug || !activeDisease){
    toast('Нет активного расчёта');
    return;
  }
  const w = parseFloat($('weight').value);
  const reg = getActiveRegimen();
  const {singleMg, dailyMg} = computeDose(reg, w);
  const ref = DB.drugs_reference[getDrugRefs(activeDrug)[0]];
  const form = ref.forms[activeFormIdx];
  const patient = $('patient-name').value || '—';
  const date = $('patient-date').value || new Date().toLocaleDateString('ru-RU');
  const doctor = $('doctor-name').value || '—';
  const age = $('patient-age').value || '—';
  let txt = 'НАЗНАЧЕНИЕ АНТИБИОТИКОТЕРАПИИ\n';
  txt += 'Дата: '+date+'\n';
  txt += 'Пациент: '+patient+' (возраст: '+age+', вес: '+w+' кг)\n';
  txt += 'Врач: '+doctor+'\n\n';
  txt += 'Диагноз: '+activeDisease.name+' (МКБ-10: '+activeDisease.mkb10.join(', ')+')\n';
  txt += 'КР МЗ РФ #'+activeDisease.cr_id+', '+activeDisease.cr_year+'\n\n';
  txt += 'Препарат: '+ref.inn+'\n';
  txt += 'Форма: '+form.concentration+'\n';
  txt += 'Разовая доза: '+Math.round(singleMg)+' мг\n';
  txt += 'Суточная доза: '+Math.round(dailyMg)+' мг\n';
  txt += 'Кратность: '+reg.freq_per_day+' р/д\n';
  txt += 'Курс: '+(reg.duration_days||'—')+'\n';
  txt += 'Путь: '+routeKeyLabel(activeRouteKey || 'im')+'\n\n';
  if(activeDrug.indication_note) txt += 'Замечание: '+activeDrug.indication_note+'\n';
  txt += '\n⚠ ЧЕРНОВИК. Требует верификации по первоисточникам КР МЗ РФ.';
  navigator.clipboard.writeText(txt).then(()=>toast('Скопировано в буфер')).catch(()=>toast('Ошибка копирования'));
}
function saveToHistory(){
  if(!activeDrug || !activeDisease){ toast('Нет активного расчёта'); return; }
  const w = parseFloat($('weight').value);
  const reg = getActiveRegimen();
  const {singleMg, dailyMg} = computeDose(reg, w);
  const ref = DB.drugs_reference[getDrugRefs(activeDrug)[0]];
  const entry = {
    ts: Date.now(),
    patient: $('patient-name').value || '',
    disease: activeDisease.name,
    drug: ref.inn,
    singleMg: Math.round(singleMg),
    dailyMg: Math.round(dailyMg),
    freq: reg.freq_per_day,
    duration: reg.duration_days || '—',
    weight: w,
    ageGroup: activeAge
  };
  const hist = JSON.parse(localStorage.getItem('antibio_history') || '[]');
  hist.unshift(entry);
  if(hist.length > 20) hist.length = 20;
  localStorage.setItem('antibio_history', JSON.stringify(hist));
  toast('Сохранено в историю');
}
function loadHistory(){
  const hist = JSON.parse(localStorage.getItem('antibio_history') || '[]');
  const list = $('history-list');
  list.innerHTML = '';
  if(hist.length === 0){
    list.innerHTML = '<p class="text-xs text-slate-400 text-center py-8">История пуста</p>';
    return;
  }
  hist.forEach((e, idx)=>{
    const div = document.createElement('div');
    div.className = 'premium-card p-3 text-xs cursor-pointer hover:bg-blue-50 dark:hover:bg-slate-700';
    const dt = new Date(e.ts);
    div.innerHTML = '<div class="flex justify-between"><span class="font-bold text-slate-700 dark:text-slate-200">'+e.drug+'</span><span class="text-slate-400">'+dt.toLocaleDateString('ru-RU')+' '+dt.toLocaleTimeString('ru-RU',{hour:'2-digit',minute:'2-digit'})+'</span></div><div class="text-slate-500 dark:text-slate-400 mt-1">'+e.disease+'</div><div class="text-slate-600 dark:text-slate-300 mt-1 font-bold">'+e.singleMg+' мг × '+e.freq+' р/д, курс '+e.duration+(e.patient?' • '+e.patient:'')+'</div>';
    list.appendChild(div);
  });
}
function openHistory(){
  loadHistory();
  $('history-drawer').classList.add('open');
  $('drawer-overlay').classList.add('open');
}
function closeHistory(){
  $('history-drawer').classList.remove('open');
  $('drawer-overlay').classList.remove('open');
}
function clearHistory(){
  if(confirm('Очистить всю историю?')){
    localStorage.removeItem('antibio_history');
    loadHistory();
    toast('История очищена');
  }
}
function updateHash(){
  if(!activeDisease || !activeDrug) return;
  const h = [activeDisease.id, activeScenario?activeScenario.id:'', activeLine?'L'+activeLine.line_number:''].join('/');
  history.replaceState(null, '', '#'+h);
}
function restoreFromHash(){
  const h = window.location.hash.slice(1);
  if(!h) return;
  const parts = h.split('/');
  const disease = DB.recommendations.find(d=>d.id === parts[0]);
  if(!disease) return;
  selectDisease(disease);
}
init();
</script>
</body>
</html>
